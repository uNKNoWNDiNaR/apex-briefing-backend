# Render example values if your persistent disk is mounted at /data
COACH_DATASET_ROOT=/data/hackathon_data
COACH_OUTPUT_ROOT=/data/outputs
COACH_RUNTIME_ROOT=/data/runtime
# Add your hosted frontend origin. Keep localhost values only if you test locally against the hosted backend.
COACH_CORS_ALLOWED_ORIGINS=https://race-vision.lovable.app,https://preview--race-vision.lovable.app,http://127.0.0.1:8080,http://localhost:8080

# Grounded AI generation
OPENAI_API_KEY=your_openai_api_key
COACH_AI_DEBRIEF_ENABLED=true
COACH_AI_DETAIL_ENABLED=true
COACH_AI_MODEL=gpt-5
COACH_AI_TEMPERATURE=0.1
